# Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=local_user
POSTGRES_DB=local_db
POSTGRES_PASSWORD=localpassword
DATABASE_URL=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}
# Optional PostgreSQL startup options (overrides secure defaults in code when set)
# POSTGRES_OPTIONS=-c search_path=public -c app.current_role=api

# Tegma/Mills (for scraping)
TEGMA_BASE_URL=https://gestaotegmatransporte.ventunolog.com.br
TEGMA_USERNAME=your_username_here
TEGMA_PASSWORD=your_password_here

# Evolution API (for WhatsApp)
EVOLUTION_API_BASE_URL=https://your-evolution-api-instance.com
EVOLUTION_API_INSTANCE=your_instance_name
EVOLUTION_API_KEY=your_api_key_here

# Notification recipients (phone numbers with country code)
NOTIFY_JEAN_PHONE=5512XXXXXXXXX
NOTIFY_JEFFERSON_PHONE=5512XXXXXXXXX
NOTIFY_SEBASTIAO_PHONE=5512XXXXXXXXX

# Admin API Key for protected endpoints
ADMIN_API_KEY=your_secure_random_key_here

# Dashboard login credentials
ADMIN_USERNAME=your_admin_username
ADMIN_PASSWORD=your_admin_password

# Development fallback (set true only for local prototyping)
ALLOW_DEV_DEFAULT_ADMIN=false

# Webhook secret for cron triggers (external schedulers like n8n)
CRON_WEBHOOK_SECRET=your_webhook_secret_here
CRON_WEBHOOK_MAX_SKEW_SECONDS=300

# Session Secret (min 32 characters)
SESSION_SECRET=at_least_32_characters_long_secret_here

# Auth rate limiting
AUTH_RATE_LIMIT_WINDOW_SECONDS=600
AUTH_RATE_LIMIT_MAX_ATTEMPTS=5
AUTH_RATE_LIMIT_BLOCK_SECONDS=900

# Global rate limiting (IP-based spray attack prevention)
GLOBAL_RATE_LIMIT_WINDOW_MS=900000
GLOBAL_RATE_LIMIT_MAX_REQUESTS=100
GLOBAL_RATE_LIMIT_BLOCK_MS=300000

# Password hashing
BCRYPT_ROUNDS=12

# Redis (optional - for distributed rate limiting and webhook deduplication)
REDIS_URL=redis://localhost:6379

# Bun API routing
# Leave API_ORIGIN empty in mono deploy (same Next.js/Vercel project for web + API).
# Set API_ORIGIN only when proxying /api/v1/* to an external Bun API origin.
API_ORIGIN=http://localhost:4000
API_PORT=4000
NEXT_PUBLIC_APP_URL=http://localhost:3000
ENABLE_DASHBOARD_MIGRATIONS=false

# Supabase pool mode (set to transaction for serverless)
POOL_MODE=transaction

# API response cache (in-memory)
API_CACHE_ENABLED=true
API_CACHE_TTL_CARGAS=20
API_CACHE_TTL_STATUS=10

# Expose DB version/max connections in /api/v1/status
# In production this should stay false unless needed for diagnostics.
STATUS_EXPOSE_DETAILS=false

# Structured logging
LOG_LEVEL=info
LOG_INCLUDE_STACK=false
